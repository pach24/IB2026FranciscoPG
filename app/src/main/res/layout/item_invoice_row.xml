<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/color_background"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvInvoiceDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/misans_bold"
        android:textColor="#2D3A3A"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="8 de marzo" />

    <TextView
        android:id="@+id/tvInvoiceType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="@font/misans_regular"
        android:textColor="#596565"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInvoiceDate"
        tools:text="Factura Luz" />

    <TextView
        android:id="@+id/tvInvoiceStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_status_unpaid"
        android:fontFamily="@font/misans_bold"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textColor="#B72727"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInvoiceType"
        tools:text="Pendiente de Pago" />

    <ImageView
        android:id="@+id/ivArrow"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_arrow_right"
        app:tint="#7A8585"
        app:layout_constraintBottom_toBottomOf="@id/tvInvoiceStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvInvoiceDate"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tvInvoiceAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/misans_regular"
        android:textColor="#596565"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@id/ivArrow"
        app:layout_constraintEnd_toStartOf="@id/ivArrow"
        app:layout_constraintTop_toTopOf="@id/ivArrow"
        tools:text="20,00 €" />

    <View
        android:id="@+id/dividerLine"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="#E5E8E8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInvoiceStatus" />

</androidx.constraintlayout.widget.ConstraintLayout>
