<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="@dimen/m3_sys_spacing_custom_10">

    <!-- Rectángulo falso para "Histórico de facturas" -->
    <View
        android:id="@+id/skeletonHistoryTitle"
        android:layout_width="@dimen/m3_comp_skeleton_header_title_width"
        android:layout_height="@dimen/m3_comp_skeleton_header_title_height"
        android:layout_marginStart="@dimen/m3_sys_spacing_4"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Rectángulo falso para el Botón Filtrar -->
    <View
        android:id="@+id/skeletonFilterBtn"
        android:layout_width="@dimen/m3_comp_skeleton_header_btn_width"
        android:layout_height="@dimen/m3_comp_skeleton_header_btn_height"
        android:layout_marginEnd="@dimen/m3_sys_spacing_3"
        android:background="@drawable/bg_skeleton_pill"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
