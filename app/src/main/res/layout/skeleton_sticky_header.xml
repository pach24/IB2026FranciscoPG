<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="10dp">

    <!-- Rectángulo falso para "Histórico de facturas" -->
    <View
        android:id="@+id/skeletonHistoryTitle"
        android:layout_width="160dp"
        android:layout_height="22dp"
        android:layout_marginStart="32dp"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Rectángulo falso para el Botón Filtrar -->
    <View
        android:id="@+id/skeletonFilterBtn"
        android:layout_width="105dp"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/margin_large"
        android:background="@drawable/bg_skeleton_pill"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
