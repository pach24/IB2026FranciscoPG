<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!-- Skeleton Fecha -->
    <View
        android:id="@+id/skeletonDate"
        android:layout_width="@dimen/m3_comp_skeleton_list_date_width"
        android:layout_height="@dimen/m3_comp_skeleton_list_date_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_2"
        android:layout_marginStart="@dimen/m3_sys_spacing_1"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Skeleton Tipo de Factura -->
    <View
        android:id="@+id/skeletonType"
        android:layout_width="@dimen/m3_comp_skeleton_list_type_width"
        android:layout_height="@dimen/m3_comp_skeleton_list_type_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_half"
        android:layout_marginStart="@dimen/m3_sys_spacing_1"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonDate" />

    <!-- Skeleton Estado (Pill) -->
    <View
        android:id="@+id/skeletonStatus"
        android:layout_width="@dimen/m3_comp_skeleton_list_status_width"
        android:layout_height="@dimen/m3_comp_skeleton_list_status_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_1"
        android:layout_marginStart="@dimen/m3_sys_spacing_1"
        android:background="@drawable/bg_skeleton_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonType" />

    <!-- Skeleton Icono Flecha (A la derecha) -->
    <View
        android:id="@+id/skeletonArrow"
        android:layout_width="@dimen/m3_comp_skeleton_list_arrow_width"
        android:layout_height="@dimen/m3_comp_skeleton_list_arrow_height"
        android:layout_marginEnd="@dimen/m3_sys_spacing_1"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/skeletonStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/skeletonDate" />

    <!-- Skeleton Importe (Antes de la flecha) -->
    <View
        android:id="@+id/skeletonAmount"
        android:layout_width="@dimen/m3_comp_skeleton_list_amount_width"
        android:layout_height="@dimen/m3_comp_skeleton_list_amount_height"
        android:layout_marginEnd="@dimen/m3_sys_spacing_custom_12"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/skeletonArrow"
        app:layout_constraintEnd_toStartOf="@id/skeletonArrow"
        app:layout_constraintTop_toTopOf="@id/skeletonArrow" />

    <!-- Línea divisoria gris -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="@dimen/m3_sys_spacing_0"
        android:layout_height="@dimen/m3_comp_divider_thickness"
        android:layout_marginTop="@dimen/m3_sys_spacing_custom_14"
        android:background="@color/color_stroke_neutral"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonStatus" />

</androidx.constraintlayout.widget.ConstraintLayout>
