<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!-- Skeleton Fecha -->
    <View
        android:id="@+id/skeletonDate"
        android:layout_width="80dp"
        android:layout_height="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Skeleton Tipo de Factura -->
    <View
        android:id="@+id/skeletonType"
        android:layout_width="70dp"
        android:layout_height="14dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonDate" />

    <!-- Skeleton Estado (Pill) -->
    <View
        android:id="@+id/skeletonStatus"
        android:layout_width="110dp"
        android:layout_height="22dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_skeleton_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonType" />

    <!-- Skeleton Icono Flecha (A la derecha) -->
    <View
        android:id="@+id/skeletonArrow"
        android:layout_width="14dp"
        android:layout_height="20dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/skeletonStatus"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/skeletonDate" />

    <!-- Skeleton Importe (Antes de la flecha) -->
    <View
        android:id="@+id/skeletonAmount"
        android:layout_width="60dp"
        android:layout_height="18dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintBottom_toBottomOf="@id/skeletonArrow"
        app:layout_constraintEnd_toStartOf="@id/skeletonArrow"
        app:layout_constraintTop_toTopOf="@id/skeletonArrow" />

    <!-- Línea divisoria gris -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="14dp"
        android:background="#E5E8E8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonStatus" />

</androidx.constraintlayout.widget.ConstraintLayout>
