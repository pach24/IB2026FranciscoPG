<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E8E8"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Skeleton Título -->
        <View
            android:id="@+id/skeletonTitle"
            android:layout_width="140dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Skeleton Subtítulo -->
        <View
            android:id="@+id/skeletonSubtitle"
            android:layout_width="90dp"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonTitle" />

        <!-- Skeleton Icono -->
        <View
            android:id="@+id/skeletonIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Skeleton Importe -->
        <View
            android:id="@+id/skeletonAmount"
            android:layout_width="110dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonSubtitle" />

        <!-- Skeleton Fechas -->
        <View
            android:id="@+id/skeletonDates"
            android:layout_width="180dp"
            android:layout_height="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonAmount" />

        <!-- Línea divisoria (La mantenemos igual que la real) -->
        <View
            android:id="@+id/dividerLine"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#E5E8E8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonDates" />

        <!-- Skeleton Pill de Estado -->
        <View
            android:id="@+id/skeletonStatus"
            android:layout_width="130dp"
            android:layout_height="28dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerLine" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
