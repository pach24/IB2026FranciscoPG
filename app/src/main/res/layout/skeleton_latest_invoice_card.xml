<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E5E8E8"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Skeleton Título (Coincide con tvCardTitle: textSize 14sp -> aprox 16dp height) -->
        <View
            android:id="@+id/skeletonTitle"
            android:layout_width="100dp"
            android:layout_height="16dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Skeleton Subtítulo (Coincide con tvInvoiceType: marginTop 4dp, textSize 10sp -> aprox 12dp height) -->
        <View
            android:id="@+id/skeletonSubtitle"
            android:layout_width="70dp"
            android:layout_height="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonTitle" />

        <!-- Skeleton Icono (Coincide con ivSupplyIcon: 38x38dp, top_toTopOf parent) -->
        <View
            android:id="@+id/skeletonIcon"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Skeleton Importe (Coincide con tvInvoiceAmount: marginTop 24dp tras el subtítulo, textSize 24sp -> aprox 28dp height) -->
        <View
            android:id="@+id/skeletonAmount"
            android:layout_width="80dp"
            android:layout_height="28dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonSubtitle" />

        <!-- Skeleton Fechas (Coincide con tvInvoiceDateRange: marginTop 4dp, textSize 10sp -> aprox 12dp height) -->
        <View
            android:id="@+id/skeletonDates"
            android:layout_width="140dp"
            android:layout_height="12dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonAmount" />

        <!-- Línea divisoria (Coincide con dividerLine: marginTop 10dp tras fechas) -->
        <View
            android:id="@+id/dividerLine"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#E5E8E8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/skeletonDates" />

        <!-- Skeleton Pill de Estado (Coincide con tvInvoiceStatus: marginTop 12dp tras el divider, height approx 24dp por padding) -->
        <View
            android:id="@+id/skeletonStatus"
            android:layout_width="100dp"
            android:layout_height="24dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_skeleton_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerLine" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
