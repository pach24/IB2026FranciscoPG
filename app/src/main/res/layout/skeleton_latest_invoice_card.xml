<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/m3_sys_spacing_custom_15">

    <!-- Skeleton Título -->
    <View
        android:id="@+id/skeletonTitle"
        android:layout_width="@dimen/m3_comp_skeleton_card_title_width"
        android:layout_height="@dimen/m3_comp_skeleton_card_title_height"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Skeleton Subtítulo -->
    <View
        android:id="@+id/skeletonSubtitle"
        android:layout_width="@dimen/m3_comp_skeleton_card_subtitle_width"
        android:layout_height="@dimen/m3_comp_skeleton_card_subtitle_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_1"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonTitle" />

    <!-- Skeleton Icono -->
    <View
        android:id="@+id/skeletonIcon"
        android:layout_width="@dimen/m3_comp_skeleton_card_icon_width"
        android:layout_height="@dimen/m3_comp_skeleton_card_icon_height"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="@dimen/m3_sys_spacing_half"/>

    <!-- Skeleton Importe -->
    <View
        android:id="@+id/skeletonAmount"
        android:layout_width="@dimen/m3_comp_skeleton_card_amount_width"
        android:layout_height="@dimen/m3_comp_skeleton_card_amount_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_2"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonSubtitle" />

    <!-- Skeleton Fechas -->
    <View
        android:id="@+id/skeletonDates"
        android:layout_width="@dimen/m3_comp_skeleton_card_dates_width"
        android:layout_height="@dimen/m3_comp_skeleton_card_dates_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_custom_12"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonAmount" />

    <!-- Línea divisoria -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="@dimen/m3_sys_spacing_0"
        android:layout_height="@dimen/m3_comp_divider_thickness"
        android:layout_marginTop="@dimen/m3_sys_spacing_custom_12"
        android:background="@color/color_stroke_neutral"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skeletonDates" />

    <!-- Skeleton Pill de Estado -->
    <View
        android:id="@+id/skeletonStatus"
        android:layout_width="@dimen/m3_comp_skeleton_card_status_width"
        android:layout_height="@dimen/m3_comp_skeleton_card_status_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_custom_12"
        android:background="@drawable/bg_skeleton_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerLine" />

</androidx.constraintlayout.widget.ConstraintLayout>
