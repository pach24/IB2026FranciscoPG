<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Indicador de arrastre superior -->
    <View
        android:id="@+id/dragHandle"
        android:layout_width="60dp"
        android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_drag_handle"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/feedback_title"
        android:textSize="20sp"
        android:fontFamily="@font/misans_bold"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        app:layout_constraintTop_toBottomOf="@id/dragHandle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/feedback_subtitle"
        android:textAlignment="center"
        android:fontFamily="@font/misans_regular"
        android:textColor="@color/light_grey"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="@color/color_stroke_neutral"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenedor de las caras distribuidas equitativamente -->
    <LinearLayout
        android:id="@+id/llFaces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:weightSum="5"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivFaceVerySad"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_face_very_sad"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivFaceSad"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_face_sad"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivFaceNeutral"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_face_neutral"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivFaceHappy"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_face_happy"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null" />

        <ImageView
            android:id="@+id/ivFaceVeryHappy"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:src="@drawable/ic_face_very_happy"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvLater"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"
        android:text="@string/feedback_later"
        android:textColor="@color/iberdrola_dark_green"
        android:textSize="16sp"
        android:fontFamily="@font/misans_bold"
        android:textStyle="bold"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/llFaces"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
