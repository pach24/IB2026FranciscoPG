<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <View
        android:id="@+id/skeletonYear"
        android:layout_width="@dimen/m3_comp_skeleton_year_width"
        android:layout_height="@dimen/m3_comp_skeleton_year_height"
        android:layout_marginTop="@dimen/m3_sys_spacing_custom_10"
        android:layout_marginBottom="@dimen/m3_sys_spacing_custom_10"
        android:layout_marginStart="@dimen/m3_sys_spacing_1"
        android:background="@drawable/bg_skeleton_placeholder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
