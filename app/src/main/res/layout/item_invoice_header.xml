<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/color_background">

    <TextView
        android:id="@+id/tvYearHeader"
        android:layout_width="@dimen/m3_sys_spacing_0"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/m3_sys_spacing_custom_10"
        android:layout_marginBottom="@dimen/m3_sys_spacing_custom_10"
        android:fontFamily="@font/misans_bold"
        android:textColor="@color/black"
        android:textSize="@dimen/m3_sys_typescale_label"
        android:paddingHorizontal="@dimen/m3_sys_spacing_1"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="2024" />

</androidx.constraintlayout.widget.ConstraintLayout>
